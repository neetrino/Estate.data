# Estate.data — environment template (copy to `.env` at repo root)
#
# File layout (dev):
#   .env                    — shared secrets (DB, JWT, Resend, R2, Redis)
#   apps/web/.env.local     — Next.js web (public + server vars for asset routes)
#   apps/api/.env.local     — Next.js API on :3001 (when scaffolded)
#   packages/db             — Prisma CLI reads root `.env` via dotenv-cli in scripts
#
# Never commit real values. Run: pnpm env:check

# ——— Application ———
NODE_ENV="development"

# apps/web — http://localhost:3000
APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_USE_MOCK_API="true"

# apps/api — http://localhost:3001
API_DEV_ORIGIN="http://localhost:3001"
# Comma-separated extra hosts for Next dev (optional)
# DEV_ALLOWED_ORIGINS="192.168.1.100"

# ——— Database (Neon PostgreSQL) ———
# DATABASE_URL — pooled connection (app runtime, Prisma queries)
# DIRECT_URL   — direct connection (migrations only)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

# ——— Authentication (admin, future) ———
JWT_SECRET="change-me-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"

# ——— Cache (Upstash Redis, future) ———
UPSTASH_REDIS_REST_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# Rate limiting (POST /api/v1/contact) — 11th request within window → 429
RATE_LIMIT_CONTACT_MAX="10"
RATE_LIMIT_CONTACT_WINDOW_SEC="60"
RATE_LIMIT_ADMIN_MAX="30"
RATE_LIMIT_ADMIN_WINDOW_SEC="60"

# Redis cache TTL for public GET lists (seconds)
CACHE_TTL_SEC="60"

# Admin seed credentials (dev only — change in production)
ADMIN_EMAIL="estate.data@gmail.com"
ADMIN_PASSWORD="CCoMJQs2uS[W~T-,pC_*3A@8RRNONi"

# API public URL (payment callbacks, optional override)
API_PUBLIC_URL="http://localhost:3001"

# ——— Email (Resend, contact form) ———
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
CONTACT_NOTIFY_EMAIL="studio@yourdomain.com"

# ——— File storage (Cloudflare R2, portfolio media) ———
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL="https://assets.yourdomain.com"

# ——— Payments (Idram sandbox) ———
IDRAM_TEST_MODE="true"

# ——— Observability (optional) ———
SENTRY_DSN=""

# ——— Figma MCP (optional, local design tools) ———
FIGMA_ACCESS_TOKEN=""
