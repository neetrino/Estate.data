generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Binary site assets (icons, hero, logos) — single source of truth for URLs served via API.
model Asset {
  id        String   @id @default(cuid())
  key       String   @unique
  mimeType  String   @map("mime_type")
  fileName  String   @map("file_name")
  data      Bytes
  byteSize  Int      @map("byte_size")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("assets")
}

/// Contact form submissions from POST /api/v1/contact.
model ContactInquiry {
  id              String    @id @default(cuid())
  name            String
  email           String
  propertyAddress String    @map("property_address")
  service         String
  preferredDate   DateTime? @map("preferred_date") @db.Date
  projectDetails  String?   @map("project_details")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@index([createdAt])
  @@map("contact_inquiries")
}

/// Admin users for JWT login (POST /api/v1/admin/auth/login).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   @default("admin")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Published portfolio tiles for GET /api/v1/portfolio.
model PortfolioProject {
  id              String                       @id @default(cuid())
  imageUrl        String                       @map("image_url")
  imageAlt        String                       @map("image_alt")
  category        String
  sortOrder       Int                          @default(0) @map("sort_order")
  featuredOnHome  Boolean                      @default(false) @map("featured_on_home")
  published       Boolean                      @default(true)
  createdAt       DateTime                     @default(now()) @map("created_at")
  updatedAt       DateTime                     @updatedAt @map("updated_at")
  translations    PortfolioProjectTranslation[]

  @@index([published, sortOrder])
  @@index([published, featuredOnHome, sortOrder])
  @@map("portfolio_projects")
}

model PortfolioProjectTranslation {
  id        String           @id @default(cuid())
  projectId String           @map("project_id")
  locale    String
  imageAlt  String?          @map("image_alt")
  category  String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, locale])
  @@index([locale])
  @@map("portfolio_project_translations")
}

/// Published resource articles — list + slug detail pages.
model Article {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  readTimeLabel String   @map("read_time_label")
  body          String   @db.Text
  sortOrder     Int      @default(0) @map("sort_order")
  published     Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  translations  ArticleTranslation[]

  @@index([published, sortOrder])
  @@map("articles")
}

model ArticleTranslation {
  id            String   @id @default(cuid())
  articleId     String   @map("article_id")
  locale        String
  title         String
  readTimeLabel String?  @map("read_time_label")
  body          String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  article       Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale])
  @@map("article_translations")
}

/// FAQ entries on the resources page.
model FaqItem {
  id           String               @id @default(cuid())
  question     String
  answer       String               @db.Text
  sortOrder    Int                  @default(0) @map("sort_order")
  published    Boolean              @default(true)
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  translations FaqItemTranslation[]

  @@index([published, sortOrder])
  @@map("faq_items")
}

model FaqItemTranslation {
  id        String   @id @default(cuid())
  faqItemId String   @map("faq_item_id")
  locale    String
  question  String
  answer    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  faqItem   FaqItem  @relation(fields: [faqItemId], references: [id], onDelete: Cascade)

  @@unique([faqItemId, locale])
  @@index([locale])
  @@map("faq_item_translations")
}

/// Section config for GET /api/v1/pricing (media vs analytics).
model PricingCategory {
  key           String                      @id
  sectionTitle  String                      @map("section_title")
  priceSuffix   String                      @map("price_suffix")
  updatedAt     DateTime                    @updatedAt @map("updated_at")
  packages      PricingPackage[]
  translations  PricingCategoryTranslation[]

  @@map("pricing_categories")
}

model PricingCategoryTranslation {
  id           String          @id @default(cuid())
  categoryKey  String          @map("category_key")
  locale       String
  sectionTitle String          @map("section_title")
  priceSuffix  String?         @map("price_suffix")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  category     PricingCategory @relation(fields: [categoryKey], references: [key], onDelete: Cascade)

  @@unique([categoryKey, locale])
  @@index([locale])
  @@map("pricing_category_translations")
}

/// Admin-editable pricing tier shown on /pricing.
model PricingPackage {
  id                  String          @id
  categoryKey         String          @map("category_key")
  name                String
  price               String
  priceSuffixOverride String?         @map("price_suffix_override")
  features            Json
  bookLabel           String          @map("book_label")
  bookHref            String          @map("book_href")
  cardAccent          String?         @map("card_accent")
  highlighted         Boolean         @default(false)
  badgeLabel          String?         @map("badge_label")
  sortOrder           Int             @default(0) @map("sort_order")
  published           Boolean         @default(true)
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")
  category            PricingCategory @relation(fields: [categoryKey], references: [key], onDelete: Cascade)

  @@index([categoryKey, published, sortOrder])
  @@map("pricing_packages")
}

enum PaymentStatus {
  pending
  paid
  failed
  cancelled
  refunded
}

/// Payment order — sandbox init + provider callbacks.
model Order {
  id          String        @id @default(cuid())
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("AMD")
  status      PaymentStatus @default(pending)
  provider    String?
  providerRef String?       @map("provider_ref")
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  payments    Payment[]

  @@index([status])
  @@index([provider, providerRef])
  @@map("orders")
}

model Payment {
  id           String        @id @default(cuid())
  orderId      String        @map("order_id")
  provider     String
  status       PaymentStatus @default(pending)
  providerData Json?         @map("provider_data")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}
