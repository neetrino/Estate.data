# @estate/web — copy to `.env.local` (Next.js loads from apps/web only)
# Database + JWT: copy from repo root `.env` (Next does not read parent .env)

# Server — mock-mode asset route uses Prisma when set
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Public — embedded in client bundle
NEXT_PUBLIC_API_URL="http://localhost:3001"
# true = same-origin assets + mocked health; false = live API on NEXT_PUBLIC_API_URL
NEXT_PUBLIC_USE_MOCK_API="true"

# Server — metadata, CORS helpers
APP_URL="http://localhost:3000"
