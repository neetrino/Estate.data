# @estate/api — copy to `.env.local` when API app is scaffolded
# Shared secrets: copy DATABASE_*, JWT_* from repo root `.env`

NODE_ENV="development"
API_DEV_ORIGIN="http://localhost:3001"
APP_URL="http://localhost:3000"

DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DATABASE_CONNECTION_LIMIT="10"
DATABASE_POOL_TIMEOUT="20"

JWT_SECRET="change-me-use-openssl-rand-base64-32"
JWT_EXPIRES_IN="7d"

# Future integrations (contact, admin upload)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@yourdomain.com"
CONTACT_NOTIFY_EMAIL="studio@yourdomain.com"

UPSTASH_REDIS_REST_URL="https://YOUR-INSTANCE.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# Rate limiting — POST /api/v1/contact (in-memory fallback when Upstash empty)
RATE_LIMIT_CONTACT_MAX="10"
RATE_LIMIT_CONTACT_WINDOW_SEC="60"

R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""
